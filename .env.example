# Público (cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Clave anon / publishable (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secreto servidor: nunca NEXT_PUBLIC. Solo en API routes.
# No es la clave publicable: es "service_role" en el mismo apartado de API.
SUPABASE_SERVICE_ROLE_KEY=

# Firma de cookies JWT y tickets de alumno (Next + Edge Functions).
# Debe ser el mismo valor que Dashboard → Project Settings → JWT → Legacy JWT secret (o cadena aleatoria ≥32 si solo usas Next).
# En Edge Functions → Secrets el nombre debe ser AIDA_JWT_SECRET (no SUPABASE_*; el panel lo bloquea).
AIDA_JWT_SECRET=

# Zona IANA para comparar "hoy" con fecha_limite_entrega del grupo (cierre de acceso alumnos).
# Opcional; por defecto America/Mexico_City.
AIDA_FECHA_LIMITE_ZONA=America/Mexico_City

# Bucket de Storage en Supabase (obligatorio para subir/descargar documentos de alumnos).
# 1) Dashboard → Storage → New bucket → mismo nombre que pongas aquí (ej. documentos-alumnos).
# 2) Sin esta variable verás: "Subida de documentos no configurada (AIDA_DOCUMENTOS_BUCKET)".
# Las rutas API usan SUPABASE_SERVICE_ROLE_KEY; no hace falta bucket público si todo pasa por el servidor.
AIDA_DOCUMENTOS_BUCKET=documentos-alumnos

# API OCR — obligatoria para extracción automática al subir documentos (CURP, acta, etc.).
# Repo y extractores: https://github.com/Cat-Not-Furry/API-OCR
# Despliegue de ejemplo (base URL, sin barra final): https://api-ocr-g2g4.onrender.com
# Handoff: https://github.com/Cat-Not-Furry/API-OCR/blob/main/handoff_aida_ocr_config.txt
#
# Trámites que acepta POST /ocr/extract (campo form "tramite") y campos que devuelve JSON "fields"
# (cada clave es { "value": string|null, "confidence": number }):
#   acta_nacimiento → nombre, fecha_nacimiento, folio, padre, madre
#   curp            → curp, nombre, entidad
#   ine             → nombre_tutor, clave_elector, ocr_id, vigencia
#   comprobante     → fecha_emision, direccion, nombre_titular
#   certificado_medico → nombre_alumno, fecha_expedicion, cedula_profesional
#
# AIDA mapea tipos de documento → trámite: acta_nacimiento, curp, ine_tutor→ine, comprobante_domicilio→comprobante, certificado_medico.
#
# En `next dev` (NODE_ENV=development), si dejas esto vacío, AIDA usa la URL demo del handoff
# (cold start posible en Render). En producción (Vercel, etc.) debes definir tu URL o la demo explícita abajo.
AIDA_OCR_API_BASE_URL=

# Producción sin URL propia: forzar la instancia demo documentada (1 / true / yes). No recomendado para datos sensibles.
AIDA_OCR_USE_RENDER_DEMO=

# --- App móvil Flutter (AppAida): dart-define en compilación (mismos valores públicos) ---
# SUPABASE_URL = NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_ANON_KEY = NEXT_PUBLIC_SUPABASE_ANON_KEY
# AIDA_API_BASE = URL de aida-web (sesión por cookies)
# AIDA_OCR_API_BASE = misma base que AIDA_OCR_API_BASE_URL (la app llama /ocr/* directo)
# Milisegundos (recomendado 90000 si puede activarse OCR.space como respaldo en el API).
AIDA_OCR_TIMEOUT_MS=90000
