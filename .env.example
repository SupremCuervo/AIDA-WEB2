# Público (cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Clave anon / publishable (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secreto servidor: nunca NEXT_PUBLIC. Solo en API routes.
# No es la clave publicable: es "service_role" en el mismo apartado de API.
SUPABASE_SERVICE_ROLE_KEY=

# Firma de cookies JWT (mín. 32 caracteres aleatorios)
AIDA_JWT_SECRET=

# Zona IANA para comparar "hoy" con fecha_limite_entrega del grupo (cierre de acceso alumnos).
# Opcional; por defecto America/Mexico_City.
AIDA_FECHA_LIMITE_ZONA=America/Mexico_City

# Bucket de Storage en Supabase (obligatorio para subir/descargar documentos de alumnos).
# 1) Dashboard → Storage → New bucket → mismo nombre que pongas aquí (ej. documentos-alumnos).
# 2) Sin esta variable verás: "Subida de documentos no configurada (AIDA_DOCUMENTOS_BUCKET)".
# Las rutas API usan SUPABASE_SERVICE_ROLE_KEY; no hace falta bucket público si todo pasa por el servidor.
AIDA_DOCUMENTOS_BUCKET=documentos-alumnos

# (Reservado) Validación automática del documento al subir — p. ej. llamada a API OCR externa.
# La lógica iría en src/app/api/alumno/subir-documento/route.ts (comentario en el archivo).
